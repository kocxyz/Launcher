{
  "name": "knockoutcitylauncher",
  "version": "2.4.5",
  "description": "Unofficial Knockout City Launcher",
  "main": "./out/main/index.js",
  "author": "ipmake.dev Systems",
  "homepage": "https://kocity.xyz",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win --config -p never",
    "build:linux": "electron-vite build && electron-builder --linux --config -p never"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/remote": "^2.1.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "axios": "^1.13.6",
    "call-bind-apply-helpers": "^1.0.2",
    "discord-rpc": "^4.0.1",
    "fs-extra": "^11.3.4",
    "jszip": "^3.10.1",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "react-color": "^2.19.3",
    "regedit": "^5.1.4",
    "sudo-prompt": "^9.2.1",
    "tree-kill": "^1.2.2",
    "unzipper": "^0.12.3",
    "vdf": "^0.0.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.0.4",
    "baseline-browser-mapping": "^2.10.7",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}
